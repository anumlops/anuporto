---
import type { DailyLog } from '../lib/neon';

export interface Props {
  entry: DailyLog;
}

const { entry } = Astro.props;
const date = new Date(entry.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<a href={`/daily/${entry.slug}`} class="block group">
  <article class="p-6 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-purple-500/30 transition-all">
    <time class="text-xs text-gray-500">{date}</time>
    <h3 class="text-lg font-semibold mt-2 mb-2 group-hover:text-purple-400 transition">{entry.title}</h3>
    <div class="flex flex-wrap gap-2">
      {(entry.tags || []).map((tag) => (
        <span class="px-2 py-1 text-xs rounded bg-purple-500/10 text-purple-400">{tag}</span>
      ))}
    </div>
  </article>
</a>
