---
import type { Tool } from '../lib/neon';

export interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<a href={`/tools/${tool.slug}`} class="block group">
  <article class="p-6 rounded-xl border border-white/10 bg-white/5 hover:bg-white/10 hover:border-emerald-500/30 transition-all">
    <h3 class="text-lg font-semibold mb-2 group-hover:text-emerald-400 transition">{tool.name}</h3>
    <p class="text-sm text-gray-400 mb-4">{tool.description}</p>
    <div class="flex flex-wrap gap-2">
      {(tool.tech_stack || []).map((tech) => (
        <span class="px-2 py-1 text-xs rounded bg-emerald-500/10 text-emerald-400">{tech}</span>
      ))}
    </div>
  </article>
</a>
