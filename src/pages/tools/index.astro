---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getTools } from '../../lib/neon';

const tools = await getTools();
---

<BaseLayout title="AI Tools" currentPath="/tools">
  <section class="max-w-6xl mx-auto px-4 pt-20 pb-16">
    <h1 class="text-4xl font-bold mb-4">AI Tools I've Built</h1>
    <p class="text-gray-400 mb-12">Tooling, wrappers, and utilities I've created for the AI ecosystem.</p>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.length > 0 ? (
        tools.map((t) => <ToolCard tool={t} />)
      ) : (
        <p class="text-gray-500 col-span-full">No tools listed yet. Check back soon!</p>
      )}
    </div>
  </section>
</BaseLayout>
