---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import DailyLogCard from '../../components/DailyLogCard.astro';
import { getDailyLogs } from '../../lib/neon';

const logs = await getDailyLogs();
---

<BaseLayout title="Daily Log" currentPath="/daily">
  <section class="max-w-3xl mx-auto px-4 pt-20 pb-16">
    <h1 class="text-4xl font-bold mb-4">Daily Advancement Log</h1>
    <p class="text-gray-400 mb-12">Daily experiments, discoveries, and builds in AI tooling.</p>
    <div class="space-y-4">
      {logs.length > 0 ? (
        logs.map((log) => <DailyLogCard entry={log} />)
      ) : (
        <p class="text-gray-500">No entries yet. Check back soon!</p>
      )}
    </div>
  </section>
</BaseLayout>
