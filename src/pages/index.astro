---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import type { Project } from '../lib/projects';

const featuredProjects: Project[] = [];
---

<BaseLayout title="Home" currentPath="/">
  <section class="max-w-6xl mx-auto px-4 pt-24 pb-16">
    <div class="max-w-3xl">
      <h1 class="text-5xl font-bold mb-4">
        Hey, I'm <span class="text-cyan-400">Anu</span>
      </h1>
      <p class="text-xl text-gray-400 mb-8">
        AI tool builder exploring the frontier of LLMs, agents, and developer tooling.
      </p>
      <div class="flex gap-4">
        <a href="/projects" class="px-6 py-3 bg-cyan-500/10 border border-cyan-500/30 rounded-lg text-cyan-400 hover:bg-cyan-500/20 transition">View Projects</a>
        <a href="/daily" class="px-6 py-3 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 transition">Daily Log</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="text-2xl font-bold mb-8">Featured Projects</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredProjects.length > 0 ? (
        featuredProjects.map((p) => <ProjectCard project={p} />)
      ) : (
        <p class="text-gray-500 col-span-full">Projects coming soon...</p>
      )}
    </div>
  </section>
</BaseLayout>
